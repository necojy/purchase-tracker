generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Item {
  id            Int            @id @default(autoincrement())
  name          String
  sellPrice     Int            // 售出價格
  originalPrice Int            @default(0) // 🌟 新增：常用店內原價
  
  // 關聯的對象
  purchaseItems PurchaseItem[] 
}

// 主訂單 (移除整筆總成本)
model PurchaseRecord {
  id             Int            @id @default(autoincrement())
  purchaseDate   DateTime       @default(now())
  location       String   
  buyer          String   
  paymentMethod  String         @default("貨到付款") 
  pickupLocation String   
  isReconciled   Boolean        @default(false)
  items          PurchaseItem[] 
}

// 訂單明細 (🌟 加上進貨單價)
model PurchaseItem {
  id             Int            @id @default(autoincrement())
  recordId       Int
  record         PurchaseRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  itemId         Int
  item           Item           @relation(fields: [itemId], references: [id])
  quantity       Int            @default(1)
  costPrice      Int            @default(0) // 🌟 每個商品的進貨單價
}