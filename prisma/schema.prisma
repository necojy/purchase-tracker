generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Item {
  id            Int            @id @default(autoincrement())
  name          String
  sellPrice     Int            // 售出價格
  originalPrice Int            @default(0) // 🌟 新增：常用店內原價
  
  // 關聯的對象
  purchaseItems PurchaseItem[] 
}

// 主訂單
model PurchaseRecord {
  id             Int            @id @default(autoincrement())
  purchaseDate   DateTime       @default(now())
  location       String   
  buyer          String   
  paymentMethod  String         @default("貨到付款") 
  pickupLocation String         // 店名 (例如: 全家神農店)
  
  // 🌟 新增：取貨類別 (SHP: 蝦皮, CVS: 超商)
  pickupCategory String         @default("SHP") 
  
  isReconciled   Boolean        @default(false)
  isRefunded     Boolean        @default(false)
  items          PurchaseItem[] 
}

// 訂單明細 (🌟 加上進貨單價)
// 訂單明細
model PurchaseItem {
  id             Int            @id @default(autoincrement())
  recordId       Int
  record         PurchaseRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  itemId         Int
  item           Item           @relation(fields: [itemId], references: [id])
  quantity       Int            @default(1)
  
  // 🌟 把這裡從 Int 改成 Float，讓系統可以儲存精準的除法小數！
  costPrice      Float          @default(0) 
}

model Store {
  id       Int    @id @default(autoincrement())
  name     String
  category String @default("SHP") // SHP: 蝦皮, CVS: 超商
}